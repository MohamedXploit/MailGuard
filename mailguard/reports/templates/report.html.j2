<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #16202a;
      --muted: #58606b;
      --bg: #f5f3ee;
      --card: #ffffff;
      --accent: #08415c;
      --critical: #a40021;
      --high: #d1495b;
      --medium: #edae49;
      --low: #00798c;
      --pass: #2b9348;
      --warn: #bc6c25;
      --fail: #c1121f;
      font-family: "Segoe UI", "Source Sans 3", sans-serif;
    }
    body {
      background: linear-gradient(180deg, #f5f3ee 0%, #eef4f7 100%);
      color: var(--ink);
      margin: 0;
      padding: 32px;
      line-height: 1.5;
    }
    header, section {
      background: var(--card);
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 16px 40px rgba(8, 65, 92, 0.08);
      margin-bottom: 24px;
    }
    h1, h2, h3 {
      margin-top: 0;
      font-family: Georgia, "Times New Roman", serif;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: 16px;
    }
    .metric {
      border: 1px solid rgba(8, 65, 92, 0.12);
      border-radius: 14px;
      padding: 16px;
      background: #fbfdfe;
    }
    .tag {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .critical { background: rgba(164, 0, 33, 0.12); color: var(--critical); }
    .high { background: rgba(209, 73, 91, 0.12); color: var(--high); }
    .medium { background: rgba(237, 174, 73, 0.16); color: #875603; }
    .low { background: rgba(0, 121, 140, 0.12); color: var(--low); }
    .pass { background: rgba(43, 147, 72, 0.12); color: var(--pass); }
    .warn { background: rgba(188, 108, 37, 0.12); color: var(--warn); }
    .fail { background: rgba(193, 18, 31, 0.12); color: var(--fail); }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }
    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(22, 32, 42, 0.08);
      vertical-align: top;
      text-align: left;
    }
    .finding {
      border-left: 4px solid rgba(8, 65, 92, 0.25);
      padding-left: 12px;
      margin-bottom: 12px;
    }
    .mono {
      font-family: "Cascadia Code", "Consolas", monospace;
      font-size: 13px;
    }
    .muted { color: var(--muted); }
  </style>
</head>
<body>
  <header>
    <h1>{{ title }}</h1>
    <p class="muted">Generated by {{ generated_for }}. Use MailGuard only against infrastructure you own or are explicitly authorized to assess.</p>
    <div class="summary-grid">
      <div class="metric"><strong>Domains Scanned</strong><br>{{ summary.scanned_domains }}</div>
      <div class="metric"><strong>Average Risk Score</strong><br>{{ summary.average_risk_score }}</div>
      <div class="metric"><strong>Critical Findings</strong><br>{{ summary.critical_findings }}</div>
      <div class="metric"><strong>High Findings</strong><br>{{ summary.high_findings }}</div>
      <div class="metric"><strong>Warnings</strong><br>{{ summary.warning_findings }}</div>
    </div>
  </header>

  {% for result in results %}
  <section>
    <h2>{{ result.domain }}</h2>
    <p>
      <span class="tag {% if result.risk.grade in ['A', 'B'] %}pass{% elif result.risk.grade == 'C' %}warn{% else %}fail{% endif %}">
        Risk {{ result.risk.score }}/100 ({{ result.risk.grade }})
      </span>
      <span class="muted">{{ result.risk.summary }}</span>
    </p>

    <h3>Control Overview</h3>
    <table>
      <thead>
        <tr>
          <th>Control</th>
          <th>Status</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>MX</td><td class="mono">{{ result.mx | length }} host(s)</td><td>{{ result.mx | map(attribute='hostname') | join(', ') }}</td></tr>
        <tr><td>SPF</td><td class="mono">{{ result.spf.status.value }}</td><td>{{ result.spf.record or 'Missing' }}</td></tr>
        <tr><td>DKIM</td><td class="mono">{{ result.dkim.status.value }}</td><td>{{ result.dkim.keys | length }} selector(s) discovered</td></tr>
        <tr><td>DMARC</td><td class="mono">{{ result.dmarc.status.value }}</td><td>{{ result.dmarc.record or 'Missing' }}</td></tr>
        <tr><td>BIMI</td><td class="mono">{{ result.bimi.status.value }}</td><td>{{ result.bimi.record or 'Not published' }}</td></tr>
        <tr><td>MTA-STS</td><td class="mono">{{ result.mta_sts.status.value }}</td><td>{{ result.mta_sts.policy.mode if result.mta_sts.policy else 'Missing' }}</td></tr>
        <tr><td>TLS-RPT</td><td class="mono">{{ result.tls_rpt.status.value }}</td><td>{{ result.tls_rpt.record or 'Missing' }}</td></tr>
        <tr><td>SMTP</td><td class="mono">{{ result.smtp.status.value }}</td><td>{{ result.smtp.issues | join('; ') }}</td></tr>
      </tbody>
    </table>

    <h3>Findings</h3>
    {% if result.findings %}
      {% for finding in result.findings %}
      <div class="finding">
        <div><span class="tag {{ finding.severity.value }}">{{ finding.severity.value }}</span> <strong>{{ finding.title }}</strong></div>
        <div>{{ finding.description }}</div>
        <div class="muted">Recommendation: {{ finding.recommendation }}</div>
        {% if finding.evidence %}<div class="mono">Evidence: {{ finding.evidence | join(' | ') }}</div>{% endif %}
      </div>
      {% endfor %}
    {% else %}
      <p>No material findings were recorded.</p>
    {% endif %}

    <h3>Recommendations</h3>
    {% if result.risk.recommendations %}
    <ul>
      {% for recommendation in result.risk.recommendations %}
      <li>{{ recommendation }}</li>
      {% endfor %}
    </ul>
    {% else %}
    <p>No urgent recommendations.</p>
    {% endif %}
  </section>
  {% endfor %}
</body>
</html>
